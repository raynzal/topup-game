                            <label for="call-of-duty-userid">User  ID:</label>
                            <input type="text" id="call-of-duty-userid" placeholder="Enter your Activision ID">
                            <button class="topup-button" onclick="processTopUp('Call of Duty')">Top Up Now</button>
                        </div>
                    </div>
                    <div class="game-card">
                        <img src="https://picsum.photos/seed/deltaforce/250/150" alt="Delta Force">
                        <h3>Delta Force</h3>
                        <div class="topup-form">
                            <label for="delta-force-amount">Select Amount:</label>
                            <select id="delta-force-amount">
                                <option value="1000">1000 Credits - $10</option>
                                <option value="5000">5000 Credits - $40</option>
                                <option value="10000">10000 Credits - $75</option>
                            </select>
                            <label for="delta-force-userid">User  ID:</label>
                            <input type="text" id="delta-force-userid" placeholder="Enter your in-game User ID">
                            <button class="topup-button" onclick="processTopUp('Delta Force')">Top Up Now</button>
                        </div>
                    </div>
                    <div class="game-card">
                        <img src="https://picsum.photos/seed/minecraft/250/150" alt="Minecraft">
                        <h3>Minecraft</h3>
                        <div class="topup-form">
                            <label for="minecraft-amount">Select Amount:</label>
                            <select id="minecraft-amount">
                                <option value="320">320 Minecoins - $5</option>
                                <option value="1020">1020 Minecoins - $15</option>
                                <option value="1720">1720 Minecoins - $25</option>
                            </select>
                            <label for="minecraft-userid">User  ID:</label>
                            <input type="text" id="minecraft-userid" placeholder="Enter your Minecraft Username">
                            <button class="topup-button" onclick="processTopUp('Minecraft')">Top Up Now</button>
                        </div>
                    </div>
                    <div class="game-card">
                        <img src="https://picsum.photos/seed/pubg/250/150" alt="PUBG">
                        <h3>PUBG</h3>
                        <div class="topup-form">
                            <label for="pubg-amount">Select Amount:</label>
                            <select id="pubg-amount">
                                <option value="60">60 UC - $1</option>
                                <option value="325">325 UC - $5</option>
                                <option value="1800">1800 UC - $25</option>
                            </select>
                            <label for="pubg-userid">User  ID:</label>
                            <input type="text" id="pubg-userid" placeholder="Enter your PUBG Character ID">
                            <button class="topup-button" onclick="processTopUp('PUBG')">Top Up Now</button>
                        </div>
                    </div>
                </div>
            </section>

            <section id="account" class="section">
                <h2>Manage Your Account</h2>
                <div class="account-section">
                    <div id="login-form">
                        <h3>Login</h3>
                        <form class="login-form">
                            <input type="email" placeholder="Email" required>
                            <input type="password" placeholder="Password" required>
                            <button type="submit" class="login-button">Login</button>
                        </form>
                        <a href="#" class="toggle-link" onclick="toggleForm()">Don't have an account? Register</a>
                    </div>
                    <div id="register-form" style="display: none;">
                        <h3>Register</h3>
                        <form class="register-form">
                            <input type="text" placeholder="Nickname" required>
                            <input type="email" placeholder="Email" required>
                            <input type="password" placeholder="Password" required>
                            <button type="submit" class="register-button">Register</button>
